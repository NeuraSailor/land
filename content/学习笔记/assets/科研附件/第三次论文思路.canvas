		},
		{
			"height": 60,
			"id": "f905cc94121c510c",
			"styleAttributes": {},
			"text": "特征提取",
			"type": "text",
			"width": 128,
			"x": -8,
			"y": 40
		},
		{
			"height": 60,
			"id": "36a8c7509106879c",
