		{
			"height": 88,
			"id": "b86d2122ecaed583",
			"styleAttributes": {},
			"text": "以脑电图 （EEG） 形式从大脑收集的活动信号用于本文描述的系统",
			"type": "text",
			"width": 260,
			"x": -360,
			"y": -80
		},
		{
			"height": 60,
